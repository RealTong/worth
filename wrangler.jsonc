{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "worth",
  "compatibility_date": "2025-08-03",
  "main": "./src/index.tsx",
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "91e2101668a441a3a81cff1eb01ae3e8"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "worth"
    }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  }
}